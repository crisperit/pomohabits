# Sandbox-masked dotfiles (character-device shims, not real files).
# Tooling injects /dev/null at these paths to deny reads; git sees the
# entries and would happily try to track them. Keep them out.
.bash_profile
.bashrc
.gitconfig
.gitmodules
.idea
.mcp.json
.profile
.ripgreprc
.vscode/*
!.vscode/launch.json
.zprofile
.zshrc

# Claude Code machine-local settings.
.claude/settings.local.json

# Sandbox-masked entries inside .claude/ (same char-device shim pattern).
.claude/agents
.claude/commands
.claude/settings.json

# --- appended by 10x-bootstrapper from flutter scaffold ---
# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Flutter compile-time env vars (copy env.json.example to env.json and fill in values)
env.json
