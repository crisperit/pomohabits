{
  "@@locale": "en",
  "appTitle": "Taskodoro",
  "@appTitle": {
    "description": "Application name shown in the app bar"
  },
  "settingsTitle": "Settings",
  "@settingsTitle": {
    "description": "Title of the Settings page"
  },
  "themeLabel": "Theme",
  "@themeLabel": {
    "description": "Section header for theme selection in Settings"
  },
  "themeSystem": "Auto",
  "@themeSystem": {
    "description": "Radio option: follow the OS theme"
  },
  "themeLight": "Light",
  "@themeLight": {
    "description": "Radio option: force light theme"
  },
  "themeDark": "Dark",
  "@themeDark": {
    "description": "Radio option: force dark theme"
  },
  "localeLabel": "Language",
  "@localeLabel": {
    "description": "Section header for language selection in Settings"
  },
  "localeSystem": "Auto",
  "@localeSystem": {
    "description": "Radio option: use the device locale"
  },
  "localeEnglish": "English",
  "@localeEnglish": {
    "description": "Radio option: force English locale"
  },
  "localePolish": "Polish",
  "@localePolish": {
    "description": "Radio option: force Polish locale"
  },
  "close": "Close",
  "@close": {
    "description": "Label for the Close button in the Settings dialog"
  },
  "authNameLabel": "Name",
  "@authNameLabel": {
    "description": "Label for the name field on the sign-up form"
  },
  "authEmailLabel": "Email",
  "@authEmailLabel": {
    "description": "Label for the email field on the auth form"
  },
  "authPasswordLabel": "Password",
  "@authPasswordLabel": {
    "description": "Label for the password field on the auth form"
  },
  "authConfirmPasswordLabel": "Confirm password",
  "@authConfirmPasswordLabel": {
    "description": "Label for the confirm-password field on the sign-up form"
  },
  "authSignInButton": "Sign in",
  "@authSignInButton": {
    "description": "Label for the sign-in submit button"
  },
  "authSignUpButton": "Sign up",
  "@authSignUpButton": {
    "description": "Label for the sign-up submit button"
  },
  "authToggleToSignUp": "Need an account? Sign up",
  "@authToggleToSignUp": {
    "description": "Link text to switch from sign-in mode to sign-up mode"
  },
  "authToggleToSignIn": "Already have an account? Sign in",
  "@authToggleToSignIn": {
    "description": "Link text to switch from sign-up mode to sign-in mode"
  },
  "authSignOut": "Sign out",
  "@authSignOut": {
    "description": "Label for the sign-out action"
  },
  "authResendButton": "Resend email",
  "@authResendButton": {
    "description": "Label for the resend confirmation email button"
  },
  "authBackToSignIn": "Back to sign in",
  "@authBackToSignIn": {
    "description": "Link text to return from the awaiting-confirmation screen to sign-in mode"
  },
  "authCheckEmailTitle": "Check your email",
  "@authCheckEmailTitle": {
    "description": "Title shown on the awaiting-confirmation screen"
  },
  "authCheckEmailBody": "We sent a confirmation link to {email}. Open it to finish signing up.",
  "@authCheckEmailBody": {
    "description": "Body text shown on the awaiting-confirmation screen",
    "placeholders": {
      "email": {
        "type": "String"
      }
    }
  },
  "authResendSuccess": "Confirmation email sent again.",
  "@authResendSuccess": {
    "description": "Feedback shown after successfully resending the confirmation email"
  },
  "authErrorNameRequired": "Please enter your name.",
  "@authErrorNameRequired": {
    "description": "Validation error when the name field is empty"
  },
  "authErrorEmailRequired": "Please enter your email.",
  "@authErrorEmailRequired": {
    "description": "Validation error when the email field is empty"
  },
  "authErrorEmailInvalid": "Please enter a valid email.",
  "@authErrorEmailInvalid": {
    "description": "Validation error when the email field contains an invalid address"
  },
  "authErrorPasswordTooShort": "Password must be at least 6 characters.",
  "@authErrorPasswordTooShort": {
    "description": "Validation error when the password is shorter than 6 characters"
  },
  "authErrorPasswordMismatch": "Passwords do not match.",
  "@authErrorPasswordMismatch": {
    "description": "Validation error when the confirm-password field does not match the password"
  },
  "authErrorUnexpected": "Something went wrong. Please try again.",
  "@authErrorUnexpected": {
    "description": "Fallback error message shown when a non-AuthException error occurs during auth"
  },
  "homeGreeting": "Hello, {name}",
  "@homeGreeting": {
    "description": "Greeting shown on the home screen with the user's name",
    "placeholders": {
      "name": {
        "type": "String"
      }
    }
  }
}
